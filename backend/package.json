{
  "scripts": {
    "dev": "bun --watch --env-file=../.env server.ts",
    "start": "bun run server.ts",
    "build": "bun build server.ts --outdir ./dist",
    "check": "tsc --noEmit",
    "migrate:json": "bun run scripts/migrate-json.ts",
    "docker:build": "docker build -t barnabus-vtt ..",
    "docker:run": "docker run -p 8080:8080 -v barnabus-data:/data barnabus-vtt"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "bun-types": "^1.1.0",
    "typescript": "^6.0.3"
  }
}
