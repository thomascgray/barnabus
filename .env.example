# Barnabus VTT — backend configuration.
#
# Copy this file to `.env` (repo root) and adjust as needed:
#     cp .env.example .env
#
# The dev backend loads this file via `bun --watch --env-file=../.env`
# (see backend/package.json). All values are optional EXCEPT
# BARNABUS_ADMIN_SECRET, which must be set for the admin API (board
# create/list/delete) to work. See backend/config.ts for the source of truth.

# --- Admin -------------------------------------------------------------------
# Shared secret gating the admin API. When empty, every admin route returns
# 503 "admin not configured". Enter this same value in the in-app admin panel
# (it's sent as a `Bearer` token). Use a long random string in production.
BARNABUS_ADMIN_SECRET=change-me

# --- Server ------------------------------------------------------------------
# Single HTTP + WebSocket port. Default: 8080.
# PORT=8080

# --- Storage -----------------------------------------------------------------
# SQLite database file. Default: ./data/barnabus.db (cwd-relative).
# In the container this is set to /data/barnabus.db.
# DB_PATH=./data/barnabus.db

# Directory for uploaded image bytes (content-addressed). Default: ./data/uploads.
# UPLOADS_DIR=./data/uploads

# Max accepted image upload size, in megabytes. Default: 25.
# MAX_UPLOAD_MB=25

# --- Static (production only) ------------------------------------------------
# Built frontend to serve in prod. Default: ../frontend/dist (relative to
# backend/). In dev this is unused — Vite serves the app and proxies /ws,
# /api, /uploads to the backend.
# STATIC_DIR=../frontend/dist
