{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "resolveJsonModule": true,
    /**
     * Typecheck JS in `.svelte` and `.js` files by default.
     * Disable checkJs if you'd like to use dynamic types in JS.
     * Note that setting allowJs false does not prevent the use
     * of JS in `.svelte` files.
     */
    "allowJs": true,
    "checkJs": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    // "bundler" (not classic "node") so TS resolves package `exports` maps —
    // required by bits-ui / @lucide/svelte subpath imports (e.g.
    // "@lucide/svelte/icons/check") that the shadcn-svelte components use. It
    // also resolves the `.js`-extension imports those components emit to their
    // `.ts` sources. This is the recommended resolution for Vite projects.
    "moduleResolution": "bundler",
    "paths": {
      "$lib": ["./src/lib"],
      "$lib/*": ["./src/lib/*"]
    },
  },
  "include": ["src/**/*.ts", "src/**/*.js", "src/**/*.svelte"]
}
